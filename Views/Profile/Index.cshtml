@model TaskFlow.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-person me-2"></i>My Profile</h2>
        <p>View your account information and statistics</p>
    </div>
    <a asp-action="Edit" class="btn btn-primary">
        <i class="bi bi-pencil-square me-1"></i> Edit Profile
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="content-card">
            <div class="card-body text-center py-4">
                <div class="rounded-circle bg-primary-soft d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-person-fill fs-1 text-primary"></i>
                </div>
                <h4 class="mb-1">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted mb-2">@Model.Email</p>
                <span class="badge bg-primary">@Model.Role</span>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="content-card mb-4">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Personal Information</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small">First Name</label>
                        <p class="fw-semibold mb-0">@Model.FirstName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Last Name</label>
                        <p class="fw-semibold mb-0">@Model.LastName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Email</label>
                        <p class="fw-semibold mb-0">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Department</label>
                        <p class="fw-semibold mb-0">@Model.Department</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Join Date</label>
                        <p class="fw-semibold mb-0">@Model.JoinDate.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-sm-4">
                <div class="stat-card text-center">
                    <div class="stat-value text-primary">@Model.AssignedTasksCount</div>
                    <div class="stat-label">Assigned Tasks</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="stat-card text-center">
                    <div class="stat-value text-success">@Model.CompletedTasksCount</div>
                    <div class="stat-label">Completed Tasks</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="stat-card text-center">
                    <div class="stat-value text-warning">@Model.PendingLeaveRequests</div>
                    <div class="stat-label">Pending Leaves</div>
                </div>
            </div>
        </div>
    </div>
</div>
