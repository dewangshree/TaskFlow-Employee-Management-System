@model TaskFlow.ViewModels.UpdateTaskStatusViewModel
@{
    ViewData["Title"] = "Update Task Status";
}

<div class="page-header">
    <h2><i class="bi bi-arrow-repeat me-2"></i>Update Task Status</h2>
    <p>Update status for: <strong>@Model.Title</strong></p>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="UpdateStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Title" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TaskFlow.Models.TaskStatus>()"></select>
                <span asp-validation-for="Status" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Update Status</button>
            <a asp-action="MyTasks" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
