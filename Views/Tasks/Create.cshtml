@model TaskFlow.ViewModels.TaskItemViewModel
@{
    ViewData["Title"] = "Create Task";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2"></i>Create Task</h2>
    <p>Add a new task and optionally assign it to an employee</p>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <partial name="_TaskForm" model="Model" />
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Create Task</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
