@model TaskFlow.ViewModels.TaskItemViewModel
@{
    ViewData["Title"] = "Task Details";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-card-text me-2"></i>@Model.Title</h2>
        <p>Task details and information</p>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Back</a>
    </div>
</div>

<div class="content-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
            <dt class="col-sm-3">Priority</dt>
            <dd class="col-sm-9"><span class="badge badge-priority-@Model.Priority.ToString().ToLower()">@Model.Priority</span></dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge badge-status-@Model.Status.ToString().ToLower()">@Model.Status</span></dd>
            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("MMMM dd, yyyy")</dd>
            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">@Model.AssignedToName</dd>
            <dt class="col-sm-3">Created By</dt>
            <dd class="col-sm-9">@Model.CreatedByName</dd>
            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</dd>
        </dl>
    </div>
</div>
