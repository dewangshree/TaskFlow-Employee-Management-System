@model TaskFlow.ViewModels.TaskItemViewModel
@{
    ViewData["Title"] = "Delete Task";
}

<div class="page-header">
    <h2><i class="bi bi-trash me-2"></i>Delete Task</h2>
    <p>Are you sure you want to delete this task?</p>
</div>

<div class="content-card">
    <div class="card-body">
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            This action cannot be undone.
        </div>
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Priority</dt>
            <dd class="col-sm-9"><span class="badge badge-priority-@Model.Priority.ToString().ToLower()">@Model.Priority</span></dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge badge-status-@Model.Status.ToString().ToLower()">@Model.Status</span></dd>
            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("MMMM dd, yyyy")</dd>
            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">@Model.AssignedToName</dd>
        </dl>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i> Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
