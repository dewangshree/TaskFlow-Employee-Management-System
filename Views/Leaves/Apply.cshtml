@model TaskFlow.ViewModels.LeaveRequestViewModel
@{
    ViewData["Title"] = "Apply for Leave";
}

<div class="page-header">
    <h2><i class="bi bi-calendar-plus me-2"></i>Apply for Leave</h2>
    <p>Submit a new leave request for admin approval</p>
</div>

<div class="content-card">
    <div class="card-body">
        <form asp-action="Apply" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="LeaveType" class="form-label"></label>
                    <select asp-for="LeaveType" class="form-select" asp-items="Html.GetEnumSelectList<TaskFlow.Models.LeaveType>()"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="field-validation-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="field-validation-error"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Reason" class="form-label"></label>
                    <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Please provide a reason for your leave request..."></textarea>
                    <span asp-validation-for="Reason" class="field-validation-error"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i> Submit Request</button>
                <a asp-action="History" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
