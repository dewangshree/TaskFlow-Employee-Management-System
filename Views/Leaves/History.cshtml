@model TaskFlow.ViewModels.LeaveListViewModel
@{
    ViewData["Title"] = "Leave History";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-clock-history me-2"></i>Leave History</h2>
        <p>View all your leave requests</p>
    </div>
    <a asp-action="Apply" class="btn btn-primary">
        <i class="bi bi-calendar-plus me-1"></i> Apply Leave
    </a>
</div>

<div class="content-card">
    <div class="card-body">
        <form method="get" class="search-bar">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small">Search</label>
                    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search by reason..." />
                </div>
                <div class="col-md-5">
                    <label class="form-label small">Status</label>
                    <select name="statusFilter" class="form-select" asp-items="Html.GetEnumSelectList<TaskFlow.Models.LeaveStatus>()">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i> Filter</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Applied On</th>
                        <th>Admin Comment</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model.LeaveRequests)
                    {
                        <tr>
                            <td>@leave.LeaveType</td>
                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.Reason</td>
                            <td><span class="badge badge-leave-@leave.Status.ToString().ToLower()">@leave.Status</span></td>
                            <td>@leave.AppliedOn.ToString("MMM dd, yyyy")</td>
                            <td>@(leave.AdminComment ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{
            ViewBag.Search = Model.Search;
            ViewBag.StatusFilter = Model.StatusFilter;
        }
        <partial name="_Pagination" model="Model.LeaveRequests" />
    </div>
</div>
