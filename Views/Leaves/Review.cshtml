@model TaskFlow.ViewModels.LeaveActionViewModel
@{
    ViewData["Title"] = "Review Leave Request";
}

<div class="page-header">
    <h2><i class="bi bi-calendar-check me-2"></i>Review Leave Request</h2>
    <p>Approve or reject leave request from @Model.EmployeeName</p>
</div>

<div class="content-card">
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.EmployeeName</dd>
            <dt class="col-sm-3">Leave Type</dt>
            <dd class="col-sm-9">@Model.LeaveType</dd>
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("MMMM dd, yyyy")</dd>
            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("MMMM dd, yyyy")</dd>
            <dt class="col-sm-3">Reason</dt>
            <dd class="col-sm-9">@Model.Reason</dd>
        </dl>

        <form asp-action="Approve" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EmployeeName" />
            <input type="hidden" asp-for="LeaveType" />
            <input type="hidden" asp-for="StartDate" />
            <input type="hidden" asp-for="EndDate" />
            <input type="hidden" asp-for="Reason" />
            <div class="mb-3">
                <label asp-for="AdminComment" class="form-label"></label>
                <textarea asp-for="AdminComment" class="form-control" rows="2" placeholder="Optional comment for approval..."></textarea>
            </div>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle me-1"></i> Approve Leave
            </button>
        </form>

        <form asp-action="Reject" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EmployeeName" />
            <input type="hidden" asp-for="LeaveType" />
            <input type="hidden" asp-for="StartDate" />
            <input type="hidden" asp-for="EndDate" />
            <input type="hidden" asp-for="Reason" />
            <div class="mb-3">
                <label asp-for="AdminComment" class="form-label">Rejection Reason</label>
                <textarea asp-for="AdminComment" class="form-control" rows="2" placeholder="Please provide a reason for rejection..."></textarea>
            </div>
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-x-circle me-1"></i> Reject Leave
            </button>
            <a asp-action="Manage" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
